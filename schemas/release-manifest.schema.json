{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://teritoriu.digital/schemas/release-manifest/1.0.0",
  "title": "Manifest release Teritoriu.digital",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "releaseId",
    "releaseTag",
    "schemaVersion",
    "transformationVersion",
    "publishedAt",
    "previousReleaseId",
    "pipelineCommit",
    "candidateSha256",
    "approval",
    "license",
    "sourceSnapshots",
    "counts",
    "quality",
    "changelogArtifact",
    "checksumArtifact",
    "artifacts"
  ],
  "properties": {
    "releaseId": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[1-9][0-9]*$"
    },
    "releaseTag": {
      "type": "string",
      "pattern": "^siruta-[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[1-9][0-9]*$"
    },
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "transformationVersion": { "type": "string", "minLength": 1 },
    "publishedAt": { "type": "string", "format": "date-time" },
    "previousReleaseId": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[1-9][0-9]*$" }
      ]
    },
    "pipelineCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "candidateSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["importRunId", "approvedBy", "approvedAt", "rationale", "candidateSha256"],
      "properties": {
        "importRunId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "approvedBy": { "type": "string", "minLength": 1 },
        "approvedAt": { "type": "string", "format": "date-time" },
        "rationale": { "type": "string", "minLength": 10 },
        "candidateSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spdx", "name", "url", "attribution"],
      "properties": {
        "spdx": { "type": "string", "const": "CC-BY-4.0" },
        "name": { "type": "string", "const": "Creative Commons Attribution 4.0 International" },
        "url": { "type": "string", "format": "uri" },
        "attribution": { "type": "string", "minLength": 1 }
      }
    },
    "sourceSnapshots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "snapshotId",
          "source",
          "publisher",
          "retrievedAt",
          "sha256",
          "sizeBytes",
          "uri"
        ],
        "properties": {
          "snapshotId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
          },
          "source": { "type": "string", "minLength": 1 },
          "publisher": { "type": "string", "minLength": 1 },
          "retrievedAt": { "type": "string", "format": "date-time" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "sizeBytes": { "type": "integer", "minimum": 1 },
          "uri": { "type": "string", "format": "uri" }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "territories",
        "countyUats",
        "localUats",
        "administrativeSubdivisions",
        "localities"
      ],
      "properties": {
        "territories": { "type": "integer", "minimum": 1 },
        "countyUats": { "type": "integer", "minimum": 0 },
        "localUats": { "type": "integer", "minimum": 0 },
        "administrativeSubdivisions": { "type": "integer", "minimum": 0 },
        "localities": { "type": "integer", "minimum": 0 }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "errors", "warnings", "reportArtifact"],
      "properties": {
        "status": { "type": "string", "enum": ["passed", "passed_with_warnings"] },
        "errors": { "type": "integer", "const": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "reportArtifact": { "type": "string", "const": "validation-report.json" }
      }
    },
    "changelogArtifact": { "type": "string", "const": "changelog.json" },
    "checksumArtifact": { "type": "string", "const": "SHA256SUMS" },
    "artifacts": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "mediaType", "sizeBytes", "sha256", "uri"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
          "mediaType": { "type": "string", "minLength": 1 },
          "sizeBytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "uri": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
