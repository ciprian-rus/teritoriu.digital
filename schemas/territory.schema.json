{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://teritoriu.digital/schemas/territory/1.0.0",
  "title": "Teritoriu",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "territoryId",
    "officialName",
    "normalizedName",
    "territoryType",
    "administrativeRole",
    "administrativeLevel",
    "status",
    "validFrom",
    "identifiers",
    "provenance"
  ],
  "properties": {
    "territoryId": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "Identificator intern persistent UUIDv7."
    },
    "officialName": { "type": "string", "minLength": 1 },
    "normalizedName": { "type": "string", "minLength": 1 },
    "shortName": { "type": ["string", "null"] },
    "territoryType": {
      "type": "string",
      "enum": [
        "country",
        "macroregion",
        "development_region",
        "county",
        "bucharest",
        "sector",
        "municipality",
        "city",
        "commune",
        "component_locality",
        "village",
        "other"
      ]
    },
    "administrativeRole": {
      "type": "string",
      "enum": [
        "country",
        "county_uat",
        "local_uat",
        "administrative_subdivision",
        "locality",
        "statistical_region"
      ]
    },
    "administrativeLevel": { "type": "integer", "minimum": 0, "maximum": 9 },
    "parentTerritoryId": {
      "type": ["string", "null"],
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "countyTerritoryId": {
      "type": ["string", "null"],
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "isUat": { "type": "boolean", "default": false },
    "isLocality": { "type": "boolean", "default": false },
    "isCountySeat": { "type": "boolean", "default": false },
    "rank": { "type": ["integer", "null"] },
    "status": { "type": "string", "enum": ["active", "inactive", "provisional"] },
    "validFrom": { "type": ["string", "null"], "format": "date" },
    "validTo": { "type": ["string", "null"], "format": "date" },
    "identifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scheme", "value", "status"],
        "properties": {
          "scheme": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["active", "historical", "provisional"] },
          "validFrom": { "type": ["string", "null"], "format": "date" },
          "validTo": { "type": ["string", "null"], "format": "date" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceSnapshotId", "sourceRecordHash"],
      "properties": {
        "sourceSnapshotId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "sourceRecordHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "transformationVersion": { "type": ["string", "null"] },
        "sourceCorrections": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "sourceValue", "canonicalValue", "ruleCode"],
            "properties": {
              "field": { "const": "NUTS" },
              "sourceValue": { "type": "string", "minLength": 1 },
              "canonicalValue": { "type": "string", "pattern": "^RO[0-9A-Z]{3}$" },
              "ruleCode": { "const": "SIRUTA_REVIEWED_NUTS_CORRECTION" }
            }
          }
        }
      }
    }
  }
}
